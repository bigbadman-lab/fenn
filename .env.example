# FENN environment variable names (Stage 1)
# Copy to .env.local and fill in values. Never commit real secrets.

# --- Required for Stage 1 ---
# Canonical site origin (e.g. http://localhost:3000 or https://imfenn.com)
NEXT_PUBLIC_SITE_URL=
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon / public key (safe for browser; subject to RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Recognised; unused until later stages ---
# Privileged Supabase key — server only; never expose to the client
SUPABASE_SERVICE_ROLE_KEY=
# Privy (Stage 3+)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# OpenAI (Camp / later AI stages)
OPENAI_API_KEY=
# Robinhood Chain RPC (Treasury / wallet reads later)
ROBINHOOD_CHAIN_RPC_URL=
# Public Treasury wallet address (economic stages; keep server-side until display is intentional)
FENN_TREASURY_ADDRESS=
# X / @askfenn agent (Stage 12+)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
