# FENN environment variable names
# Copy to .env.local and fill in values. Never commit real secrets.

# --- Required (Stage 1 foundation + Stage 3 identity) ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-only secrets (never NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=
PRIVY_APP_SECRET=

# Stage 6 admin allowlist — comma-separated EVM addresses (never NEXT_PUBLIC_*)
# Example: FENN_ADMIN_WALLETS=0xabc...,0xdef...
FENN_ADMIN_WALLETS=

# --- Recognised; unused until later stages ---
# Camp AI (Stage 7+) — server-only. Site builds without it; Camp turns fail closed.
# Never use NEXT_PUBLIC_OPENAI_API_KEY.
OPENAI_API_KEY=
ROBINHOOD_CHAIN_RPC_URL=
FENN_TREASURY_ADDRESS=
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
